{
  "entities": {
    "CafeItem": {
      "title": "Cafe Item",
      "description": "An item sold in the cafe",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "detail": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["In Stock", "Sold Out"] }
      },
      "required": ["title", "price", "category", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "cashierId": { "type": "string" }
      },
      "required": ["items", "totalAmount", "timestamp", "cashierId"]
    }
  },
  "firestore": {
    "/cafe/{itemId}": {
      "schema": { "$ref": "#/entities/CafeItem" },
      "description": "Cafe items available for sale"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Completed orders"
    }
  }
}
