rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: cafe
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required) - Name of the item
    //   - detail: string (optional) - Description of the item
    //   - price: number (required) - Price of the item
    //   - image: string (optional) - Image URL from Cloudinary
    //   - category: string (required) - Category (e.g., Coffee, Bakery)
    //   - unit: string (optional) - Unit (e.g., Cup, Piece)
    //   - status: string (required) - 'In Stock' or 'Sold Out'
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - items: list (required) - List of items ordered
    //   - total: number (required) - Total price
    //   - createdAt: timestamp (required) - Time of order
    //   - cashierId: string (required) - UID of the cashier
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidCafeItem() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'price', 'category', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.status is string && data.status in ['In Stock', 'Sold Out'] &&
             (!('unit' in data) || (data.unit is string && data.unit.size() < 50)) &&
             (!('detail' in data) || (data.detail is string && data.detail.size() < 500)) &&
             (!('image' in data) || (data.image is string && data.image.size() < 1000));
    }

    function isValidOrder() {
      let data = request.resource.data;
      return hasRequiredFields(['items', 'totalAmount', 'timestamp', 'cashierId']) &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.timestamp is timestamp &&
             data.cashierId is string && data.cashierId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /cafe/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCafeItem();
      allow update: if isAuthenticated() && isValidCafeItem();
      allow delete: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow create: if isAuthenticated() && isValidOrder();
      allow read: if isAuthenticated();
      allow update, delete: if false; // Orders are immutable
    }
  }
}
